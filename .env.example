# Copy to .env for local dev, and set the SAME keys in the Vercel dashboard
# (Project -> Settings -> Environment Variables) for production.
#
# VITE_* keys are PUBLIC — they are baked into the client bundle at build time,
# so they must be present at BUILD time on Vercel.
# All others are SERVER-ONLY (read at runtime inside the /api/* serverless
# functions) and must NEVER be exposed with a VITE_ prefix.

# --- Supabase (client) ---
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# --- Supabase (server) ---
SUPABASE_PROJECT_ID=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- TMDB ---
TMDB_API_KEY=

# --- Consumet (self-hosted instance) ---
CONSUMET_BASE_URL=

# --- CAPTCHA solving (scrapers) ---
CAPSOLVER_API_KEY=

# --- AI chat (server-only) ---
OPENROUTER_API_KEY=
GEMINI_API_KEY=
GEMINI_API_KEY_2=

# --- Browser proxy pool (server-only) ---
# Format per entry: host:port:username:password  (comma-separated).
PROXY_LIST=

# --- Public site URL ---
VITE_BASE_URL=
PUBLIC_URL=
